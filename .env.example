# Primary Prisma connection URL



DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Optional: enforce strict TLS certificate verification in all environments
REQUIRE_STRICT_DB_SSL="false"

# Optional: force no-verify SSL mode (development troubleshooting only)
ALLOW_INSECURE_DB_SSL="false"

# Supabase Auth (incremental integration)
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# Local JWT auth (used by /api/auth/login)
AUTH_JWT_SECRET="change-this-to-a-long-random-secret"
# Optional token expiry, default is 12h
AUTH_JWT_EXPIRES_IN="12h"

# OTP provider for activation routes
# local    -> use temporary database-backed OTP flow
# supabase -> local activation endpoints return 503 until Supabase OTP flow is wired
# Defaults: non-production=local, production=supabase
OTP_PROVIDER="local"
